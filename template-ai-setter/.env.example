# ────────────────────────────────────────────────────────────────────────────
# AI Appointment Setter — environment variables
# Copy this file to `.env.local` and fill in YOUR OWN values. Never commit .env.local.
# ────────────────────────────────────────────────────────────────────────────

# === REQUIRED ===

# Your own client's slug — the row in your `clients` table that represents YOUR
# own setter (the one running in your own DMs). Pick anything lowercase, e.g. your brand.
OWNER_CLIENT_SLUG=owner

# Anthropic — the AI brain. Get it at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase — your database. Project Settings → API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GoHighLevel inbound webhook secret. Make up a long random string; it must match
# the `x-webhook-secret` header you set on the GHL webhook that points here.
GHL_WEBHOOK_SECRET=make-up-a-long-random-string

# Telegram — your remote control. Bot token from @BotFather, your user id from @userinfobot.
TELEGRAM_BOT_TOKEN=123456789:your-bot-token
TELEGRAM_AUTHORIZED_USER_ID=your-telegram-user-id
# Optional: where pings are sent. Defaults to TELEGRAM_AUTHORIZED_USER_ID if blank.
TELEGRAM_CHAT_ID=

# Protects the scheduled jobs + the on-demand DM-intelligence endpoint. Random strings.
CRON_SECRET=make-up-a-long-random-string
DM_INTEL_SECRET=make-up-a-long-random-string

# === BRANDING ===

# Your dashboard / HQ name (shown in the header + the HQ tab).
NEXT_PUBLIC_BRAND_NAME=AI SETTER

# === OPTIONAL ===

# Voice notes. SHIPS OFF — Instagram can't receive audio through GHL yet. Leave blank.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Transcribing inbound AUDIO DMs from leads (optional). https://console.groq.com
GROQ_API_KEY=

# NOTE: GoHighLevel API keys are NOT set here — each client's GHL key is stored
# per-business in the `clients` table row, never in the environment.
