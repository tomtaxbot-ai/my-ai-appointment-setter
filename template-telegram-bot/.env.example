# ── CLAUDE (Anthropic) ──
ANTHROPIC_API_KEY=your-anthropic-api-key   # from https://console.anthropic.com

# ── TELEGRAM ──
TELEGRAM_BOT_TOKEN=123456789:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # from @BotFather
TELEGRAM_AUTHORIZED_USER_ID=123456789                # owner's Telegram user id (from @userinfobot)

# ── SUPABASE (the setter's database) ──
AISETTER_SUPABASE_URL=https://yourproject.supabase.co            # Supabase project URL
AISETTER_SUPABASE_SERVICE_KEY=your-supabase-service-role-key     # Supabase service-role key (server-side only)

# ── OWNER IDENTITY (genericizes all persona/prompt text + DB lookups) ──
OWNER_CLIENT_SLUG=owner          # the clients.slug row this bot controls in Supabase
OWNER_CLIENT_ID=                 # the clients.id (UUID) row this bot controls in Supabase
OWNER_NAME=the owner             # the owner's name, used in the AI's spoken/persona text
BUSINESS_NAME=the business       # the owner's business name, used in the AI's persona text
OWNER_TIMEZONE=UTC               # owner's IANA timezone for "today"/reminders, e.g. America/New_York

# ── AI-SETTER APP (the Next.js deployment that runs the DM analyser) ──
AISETTER_BASE_URL=https://your-ai-setter.vercel.app   # your ai-setter deployment URL
DM_INTEL_SECRET=your-dm-intel-secret                  # shared secret to trigger the DM-intel analysis endpoint
CRON_SECRET=your-cron-secret                          # fallback secret if DM_INTEL_SECRET is unset
